<!-- views/partials/nav.ejs
     Top contact strip + main site navigation. `currentPath` (set in server.js
     res.locals) is used to highlight the active link. -->

<div class="topbar">
  <div class="topbar__inner">
    <div class="topbar__contact">
      <a href="tel:+919958449002">📞 +91-9958 449002</a>
      <a href="mailto:info@puliziafm.com">✉️ info@puliziafm.com</a>
    </div>
    <div class="topbar__meta">
      <span>ISO 9001:2015 Certified</span>
      <span>Noida, Uttar Pradesh</span>
    </div>
  </div>
</div>

<header class="site-header">
  <div class="site-header__inner">
    <a href="/" class="brand">
      <span class="brand__mark">PFM</span>
      <span class="brand__name">Pulizia<em>FM</em></span>
    </a>

    <button class="nav-toggle" id="navToggle" aria-label="Toggle navigation" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>

    <nav class="main-nav" id="mainNav">
      <a href="/" class="<%= currentPath === '/' ? 'is-active' : '' %>">Home</a>
      <a href="/about" class="<%= currentPath === '/about' ? 'is-active' : '' %>">About Us</a>
      <a href="/services" class="<%= currentPath.startsWith('/services') ? 'is-active' : '' %>">Services</a>
      <a href="/clients" class="<%= currentPath === '/clients' ? 'is-active' : '' %>">Clients</a>
      <a href="/blog" class="<%= currentPath.startsWith('/blog') ? 'is-active' : '' %>">Blog</a>
      <a href="/contact" class="<%= currentPath === '/contact' ? 'is-active' : '' %>">Contact</a>
      <a href="/contact" class="nav-cta">Request a Quote</a>
      <% if (typeof isAdmin !== 'undefined' && isAdmin) { %>
        <a href="/admin/dashboard" class="nav-admin">Admin ↗</a>
      <% } %>
    </nav>
  </div>
</header>
