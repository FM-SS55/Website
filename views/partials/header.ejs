<!-- views/partials/header.ejs
     Included at the top of every public + admin page. Expects `title` to be
     passed in from the route handler. -->
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title : 'Pulizia FM Services' %></title>
  <meta name="description" content="Pulizia FM Services — integrated facility management: housekeeping, security, landscaping, pest control, and more.">
  <link rel="icon" href="/favicon.ico">

  <!-- Fonts: Big Shoulders Display (headlines), Work Sans (body), IBM Plex Mono (labels/data) -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Big+Shoulders+Display:wght@600;700;800&family=Work+Sans:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">

  <link rel="stylesheet" href="/css/style.css">
</head>
