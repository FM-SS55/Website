<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> — Pulizia FM Admin</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Big+Shoulders+Display:wght@700;800&family=Work+Sans:wght@400;500;600&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body class="admin-body">
  <div class="admin-shell">
    <%- include('../partials/admin-sidebar') %>

    <main class="admin-main">
      <div class="admin-topline">
        <h1 class="admin-title">Services</h1>
        <a href="/" target="_blank" class="admin-view-site">View Live Site ↗</a>
      </div>

      <!-- ---- Add / Edit form ---- -->
      <div class="admin-panel">
        <h2><%= editing ? 'Edit Service' : 'Add New Service' %></h2>
        <form
          class="admin-form"
          action="<%= editing ? '/admin/services/' + editing.id : '/admin/services' %>"
          method="POST"
          enctype="multipart/form-data"
        >
          <% if (editing) { %><input type="hidden" name="_method" value="PUT"><% } %>

          <div class="admin-form-row">
            <div>
              <label for="title">Title</label>
              <input type="text" id="title" name="title" value="<%= editing ? editing.title : '' %>" required>
            </div>
            <div>
              <label for="slug">URL Slug</label>
              <input type="text" id="slug" name="slug" value="<%= editing ? editing.slug : '' %>" placeholder="e.g. mechanized-housekeeping" required>
            </div>
          </div>

          <div>
            <label for="short_description">Short Description (shown on cards)</label>
            <textarea id="short_description" name="short_description" rows="2"><%= editing && editing.short_description ? editing.short_description : '' %></textarea>
          </div>

          <div>
            <label for="full_description">Full Description (shown on the service page)</label>
            <textarea id="full_description" name="full_description" rows="4"><%= editing && editing.full_description ? editing.full_description : '' %></textarea>
          </div>

          <% if (editing && editing.image_url) { %>
            <div class="current-image">
              <img src="<%= editing.image_url %>" alt="Current service image">
              <span style="font-size: 13px; color: var(--muted);">Current image — upload a new one below to replace it.</span>
            </div>
            <input type="hidden" name="image_url_existing" value="<%= editing.image_url %>">
          <% } %>
          <div>
            <label for="image">Service Image (optional)</label>
            <input type="file" id="image" name="image" accept="image/*">
          </div>

          <div class="admin-form-row">
            <div>
              <label for="icon">Icon Keyword</label>
              <input type="text" id="icon" name="icon" value="<%= editing && editing.icon ? editing.icon : '' %>" placeholder="e.g. sparkles">
            </div>
            <div>
              <label for="sort_order">Sort Order</label>
              <input type="number" id="sort_order" name="sort_order" value="<%= editing ? editing.sort_order : 0 %>">
            </div>
          </div>

          <label class="admin-checkbox">
            <input type="checkbox" name="is_active" <%= (!editing || editing.is_active) ? 'checked' : '' %>>
            Active (visible on site)
          </label>

          <div class="admin-form-actions">
            <button type="submit" class="btn-admin btn-admin-primary"><%= editing ? 'Save Changes' : 'Add Service' %></button>
            <% if (editing) { %>
              <a href="/admin/services" class="btn-admin btn-admin-ghost">Cancel</a>
            <% } %>
          </div>
        </form>
      </div>

      <!-- ---- List ---- -->
      <div class="admin-panel">
        <h2>All Services</h2>
        <% if (services && services.length > 0) { %>
          <table class="admin-table">
            <thead>
              <tr><th>Title</th><th>Slug</th><th>Order</th><th>Status</th><th></th></tr>
            </thead>
            <tbody>
              <% services.forEach(s => { %>
                <tr>
                  <td><%= s.title %></td>
                  <td><code><%= s.slug %></code></td>
                  <td><%= s.sort_order %></td>
                  <td><span class="badge <%= s.is_active ? 'badge--on' : 'badge--off' %>"><%= s.is_active ? 'Active' : 'Inactive' %></span></td>
                  <td>
                    <div class="row-actions">
                      <a href="/services/<%= s.slug %>" target="_blank">View</a>
                      <a href="/admin/services/<%= s.id %>/edit">Edit</a>
                      <form action="/admin/services/<%= s.id %>" method="POST" onsubmit="return confirm('Delete this service?');">
                        <input type="hidden" name="_method" value="DELETE">
                        <button type="submit" class="danger">Delete</button>
                      </form>
                    </div>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        <% } else { %>
          <p style="color: var(--muted); font-size: 14px;">No services yet — add one above.</p>
        <% } %>
      </div>
    </main>
  </div>
</body>
</html>
