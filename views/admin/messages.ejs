<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> — Pulizia FM Admin</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Big+Shoulders+Display:wght@700;800&family=Work+Sans:wght@400;500;600&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body class="admin-body">
  <div class="admin-shell">
    <%- include('../partials/admin-sidebar') %>

    <main class="admin-main">
      <div class="admin-topline">
        <h1 class="admin-title">Contact Messages</h1>
        <a href="/" target="_blank" class="admin-view-site">View Live Site ↗</a>
      </div>

      <div class="admin-panel">
        <% if (messages && messages.length > 0) { %>
          <table class="admin-table">
            <thead>
              <tr><th>Name</th><th>Email</th><th>Phone</th><th>Message</th><th>Received</th><th></th></tr>
            </thead>
            <tbody>
              <% messages.forEach(m => { %>
                <tr>
                  <td><%= m.name %></td>
                  <td><a href="mailto:<%= m.email %>"><%= m.email %></a></td>
                  <td><%= m.phone || '—' %></td>
                  <td style="max-width: 320px;"><%= m.message %></td>
                  <td><%= new Date(m.created_at).toLocaleString() %></td>
                  <td>
                    <form action="/admin/messages/<%= m.id %>" method="POST" onsubmit="return confirm('Delete this message?');">
                      <input type="hidden" name="_method" value="DELETE">
                      <button type="submit" class="row-actions danger" style="font-family: var(--font-mono); font-size:12px; background:none; border:none; cursor:pointer;">Delete</button>
                    </form>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        <% } else { %>
          <p style="color: var(--muted); font-size: 14px;">No messages received yet.</p>
        <% } %>
      </div>
    </main>
  </div>
</body>
</html>
