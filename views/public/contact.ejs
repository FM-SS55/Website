<%- include('../partials/header') %>
<%- include('../partials/nav') %>

<section class="page-hero">
  <div class="container">
    <div class="breadcrumb"><a href="/" style="color:inherit;">Home</a> / Contact Us</div>
    <h1>Contact Us</h1>
  </div>
</section>

<section class="section">
  <div class="container" style="display:grid; grid-template-columns: 1fr 1fr; gap: 60px;">
    <div>
      <div class="section-eyebrow">Get In Touch</div>
      <h2 class="section-title">Let's talk about your site</h2>
      <p class="section-desc" style="margin-bottom: 30px;">Send us a few details and our team will get back to you, usually within one business day.</p>

      <% if (typeof submitted !== 'undefined' && submitted) { %>
        <div class="form-success">Thanks — your message has been received. We'll be in touch shortly.</div>
      <% } %>
      <% if (typeof error !== 'undefined' && error) { %>
        <div class="form-error"><%= error %></div>
      <% } %>

      <form action="/contact" method="POST" class="form-grid">
        <div class="form-field">
          <label for="name">Full Name</label>
          <input type="text" id="name" name="name" required>
        </div>
        <div class="form-field">
          <label for="email">Email Address</label>
          <input type="email" id="email" name="email" required>
        </div>
        <div class="form-field">
          <label for="phone">Phone Number</label>
          <input type="tel" id="phone" name="phone">
        </div>
        <div class="form-field">
          <label for="message">Message</label>
          <textarea id="message" name="message" rows="5" required></textarea>
        </div>
        <button type="submit" class="btn btn-primary" style="justify-self: start;">Send Message</button>
      </form>
    </div>

    <div>
      <div class="section-eyebrow">Reach Us Directly</div>
      <h2 class="section-title">Contact Details</h2>
      <div style="margin-top: 20px; display:grid; gap: 16px; font-size: 15px;">
        <div><strong>Phone:</strong> <a href="tel:+919958449002">+91-9958 449002</a></div>
        <div><strong>Email:</strong> <a href="mailto:info@puliziafm.com">info@puliziafm.com</a></div>
        <div><strong>Location:</strong> Noida, Uttar Pradesh, India</div>
        <div><strong>Certification:</strong> ISO 9001:2015</div>
      </div>
    </div>
  </div>
</section>

<%- include('../partials/footer') %>
